# Copy to .env and fill in the keys. Never commit .env.

DOMAIN=apparel_ecommerce

# Generation + voice: Groq (fast, cheap, OpenAI-compatible)
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL_SMALL=llama-3.1-8b-instant
GROQ_MODEL_LARGE=llama-3.3-70b-versatile
TRANSCRIBE_PROVIDER=groq
WHISPER_MODEL=whisper-large-v3

# Spoken voice (text-to-speech). Leave TTS_PROVIDER=none to use the browser's built-in voice for
# free; set it to "elevenlabs" with a key for a real, human-sounding voice. The key stays on the
# server (the browser calls /api/tts). Free tier is enough for a demo; Flash v2.5 is fast + cheap.
TTS_PROVIDER=none
ELEVENLABS_API_KEY=your_elevenlabs_key_here
ELEVENLABS_MODEL=eleven_flash_v2_5
# Premade voices work on the free tier (Voice-Library voices need a paid plan): assistant Aria is
# "Sarah" (warm, natural young woman), human specialist Sara is "Jessica" (friendly, conversational
# woman). Override with any voice id from your ElevenLabs account.
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
ELEVENLABS_AGENT_VOICE_ID=cgSgspJ2msm6clMCkdW9

# Retrieval: Cohere embeddings + reranker (one key covers both)
EMBED_PROVIDER=cohere
EMBED_MODEL=embed-v4.0
RERANK_PROVIDER=cohere
RERANK_MODEL=rerank-v3.5
# Primary Cohere key. A free Trial key works here as the first layer.
COHERE_API_KEY=your_cohere_trial_key_here
# Optional second key, used ONLY when the primary returns 429 (trial monthly cap or per-minute
# limit). Put a paid Production key here to make it the automatic backstop. Leave blank to skip it;
# if both keys fail, retrieval falls back to local sparse search so the answer still lands.
COHERE_API_KEY_FALLBACK=your_cohere_production_key_here

# Stores (docker compose, local)
VECTOR_PROVIDER=qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
POSTGRES_URL=postgresql://skein:skein@localhost:5432/skein
GRAPH_PROVIDER=neo4j
NEO4J_URL=http://localhost:7474
NEO4J_USER=neo4j
NEO4J_PASSWORD=skein_password
MLFLOW_TRACKING_URI=http://localhost:5000

# App
RATE_LIMIT=300/minute
CHAT_BRAIN=linear
REVIEW_QUEUE_DB=.review_queue.db
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DEMO_READONLY=false

# Auth. SKEIN_ENV=production forces a real JWT_SECRET and TURNSTILE_SECRET_KEY.
# SKEIN_ENV=dev
JWT_SECRET=change-me-to-a-long-random-string
AUTH_DB_PATH=.auth.db
DEMO_USERNAME=demo
DEMO_PASSWORD=Canada54321
# The demo shopper's account identity: greets them by name and unlocks their own orders
# when logged in (the login proves who they are, so no re-typing name+email).
DEMO_CUSTOMER_NAME=Jordan Avery
DEMO_CUSTOMER_EMAIL=info@esteki.ca
TURNSTILE_SECRET_KEY=

# Landing-page gate: one shared credential you email to reviewers to reach the demo. Leave empty
# to leave the gate open in local dev. The web app also needs NEXT_PUBLIC_TURNSTILE_SITE_KEY set
# in web/.env.local for the captcha widget.
GATE_USERNAME=
GATE_PASSWORD=

# Optional: Langfuse tracing (set both keys to enable)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
