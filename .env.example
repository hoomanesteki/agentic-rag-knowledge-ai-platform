# Copy this file to .env and fill in the keys. Never commit .env.

# ---- Domain ----
# Which domain pack to load. Change this one value to swap the topic.
DOMAIN=apparel_ecommerce

# ---- Models (all hosted, nothing runs on your machine) ----
# App LLM: Groq, OpenAI compatible. Small tasks use the instant model, synthesis uses the large one.
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL_SMALL=llama-3.1-8b-instant
GROQ_MODEL_LARGE=llama-3.3-70b-versatile

# Embeddings + reranker: Voyage, hosted and multilingual. One account covers both.
EMBED_PROVIDER=voyage
EMBED_MODEL=voyage-3-large
VOYAGE_API_KEY=your_voyage_key_here
RERANK_PROVIDER=voyage
RERANK_MODEL=rerank-2.5

# ---- Stores (run in Docker locally, added at their milestones) ----
VECTOR_PROVIDER=qdrant
QDRANT_URL=http://localhost:6333
POSTGRES_URL=postgresql://skein:skein@localhost:5432/skein
# Knowledge graph (M5). memory = offline fake; neo4j = the container from docker-compose.
# The adapter talks to Neo4j's HTTP API on 7474 (not the bolt port), so no driver is needed.
GRAPH_PROVIDER=neo4j
NEO4J_URL=http://localhost:7474
NEO4J_USER=neo4j
NEO4J_PASSWORD=skein_password
# MLFLOW_URI=http://localhost:5000       # added at M8

# ---- App behavior ----
RATE_LIMIT=30/minute
# comma-separated origins allowed to call the API (no trailing slashes)
ALLOWED_ORIGINS=http://localhost:3000
# NEXT_PUBLIC_API_URL is read by the web app; set it in web/.env.local (see web/.env.example)
DEMO_READONLY=true
MAX_STEPS=4
AGENT_BUDGET=6

# ---- Auth + captcha (M3.3) ----
JWT_SECRET=change-me-to-a-long-random-string
AUTH_DB_PATH=.auth.db
DEMO_USERNAME=demo
DEMO_PASSWORD=skein-demo-2026
# Turnstile: leave the secret empty in dev to bypass the captcha check.
TURNSTILE_SECRET_KEY=
# NEXT_PUBLIC_TURNSTILE_SITE_KEY is read by the web app; set it in web/.env.local.
