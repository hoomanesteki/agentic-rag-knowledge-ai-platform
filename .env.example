# Copy to .env and fill in the keys. Never commit .env.

DOMAIN=apparel_ecommerce

# Generation + voice: Groq (fast, cheap, OpenAI-compatible)
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL_SMALL=llama-3.1-8b-instant
GROQ_MODEL_LARGE=llama-3.3-70b-versatile
TRANSCRIBE_PROVIDER=groq
WHISPER_MODEL=whisper-large-v3

# Retrieval: Cohere embeddings + reranker (one key covers both)
EMBED_PROVIDER=cohere
EMBED_MODEL=embed-v4.0
RERANK_PROVIDER=cohere
RERANK_MODEL=rerank-v3.5
COHERE_API_KEY=your_cohere_key_here

# Stores (docker compose, local)
VECTOR_PROVIDER=qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
POSTGRES_URL=postgresql://skein:skein@localhost:5432/skein
GRAPH_PROVIDER=neo4j
NEO4J_URL=http://localhost:7474
NEO4J_USER=neo4j
NEO4J_PASSWORD=skein_password
MLFLOW_TRACKING_URI=http://localhost:5000

# App
RATE_LIMIT=30/minute
CHAT_BRAIN=linear
REVIEW_QUEUE_DB=.review_queue.db
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DEMO_READONLY=false

# Auth. SKEIN_ENV=production forces a real JWT_SECRET and TURNSTILE_SECRET_KEY.
# SKEIN_ENV=dev
JWT_SECRET=change-me-to-a-long-random-string
AUTH_DB_PATH=.auth.db
DEMO_USERNAME=demo
DEMO_PASSWORD=Canada54321
TURNSTILE_SECRET_KEY=

# Optional: Langfuse tracing (set both keys to enable)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
